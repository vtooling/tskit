{
  "name": "@vtooling/tskit",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./fs": "./fs/mod.ts",
    "./path": "./path/mod.ts",
    "./process": "./process/mod.ts",
    "./http": "./http/mod.ts",
    "./config": "./config/mod.ts",
    "./system": "./system/mod.ts"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.1.6",
    "@std/yaml": "jsr:@std/yaml@^1.1.2",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "tasks": {
    "test": "deno test --allow-all --coverage=cov_profile",
    "coverage": "deno coverage cov_profile",
    "check": "deno fmt --check && deno lint && deno check mod.ts",
    "fmt": "deno fmt",
    "build": "deno check mod.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
